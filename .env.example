# Bind address (default: 127.0.0.1)
HOST=0.0.0.0

# Listen port (default: 9000)
PORT=9000

# HTTP/HTTPS/SOCKS proxy for outbound requests to DeepL
# Supports: http://, https://, socks4://, socks4a://, socks5://, socks5h://
#   socks5  = SOCKS5 with local DNS resolution
#   socks5h = SOCKS5 with remote DNS resolution (proxy resolves)
#   socks4  = SOCKS4 proxy
#   socks4a = SOCKS4A with remote DNS resolution
PROXY_LIST=socks5://127.0.0.1:1080
